Z80AS 4.8	Source file: BIOS01   	Page    1

                                ;	Z80 CBIOS for Z80-Simulator
                                ;
                                ;	Copyright (C) 1988-2007 by Udo Munk
                                ;
  0040  =                       MSIZE	EQU	64		;cp/m version memory size in kilobytes
                                ;
                                ;	"bias" is address offset from 3400H for memory systems
                                ;	than 16K (referred to as "b" throughout the text).
                                ;
  B000  =                       BIAS	EQU	(MSIZE-20)*1024
  E400  =                       CCP	EQU	3400H+BIAS	;base of ccp
  EC06  =                       BDOS	EQU	CCP+806H	;base of bdos
  FA00  =                       BIOS	EQU	CCP+1600H	;base of bios
  002C  =                       NSECTS	EQU	(BIOS-CCP)/128	;warm start sector count
  0004  =                       CDISK	EQU	0004H		;current disk number 0=A,...,15=P
  0003  =                       IOBYTE	EQU	0003H		;intel i/o byte
                                ;
                                ;	I/O ports
                                ;
  0000  =                       CONSTA	EQU	0		;console status port
  0001  =                       CONDAT	EQU	1		;console data port
  0002  =                       PRTSTA	EQU	2		;printer status port
  0003  =                       PRTDAT	EQU	3		;printer data port
  0005  =                       AUXDAT	EQU	5		;auxiliary data port
  000A  =                       FDCD	EQU	10		;fdc-port: # of drive
  000B  =                       FDCT	EQU	11		;fdc-port: # of track
  000C  =                       FDCS	EQU	12		;fdc-port: # of sector
  000D  =                       FDCOP	EQU	13		;fdc-port: command
  000E  =                       FDCST	EQU	14		;fdc-port: status
  000F  =                       DMAL	EQU	15		;dma-port: dma address low
  0010  =                       DMAH	EQU	16		;dma-port: dma address high
                                ;
  FA00  =                       	ORG	BIOS		;origin of this program
                                ;
                                ;	jump vector for individual subroutines
                                ;
  FA00  C3 FB6E                 	JP	BOOT		;cold start
  FA03  C3 FB81                 WBOOTE: JP	WBOOT		;warm start
  FA06  C3 FBEC                 	JP	CONST		;console status
  FA09  C3 FBEF                 	JP	CONIN		;console character in
  FA0C  C3 FBF9                 	JP	CONOUT		;console character out
  FA0F  C3 FBFD                 	JP	LIST		;list character out
  FA12  C3 FC04                 	JP	PUNCH		;punch character out
  FA15  C3 FC08                 	JP	READER		;reader character in
  FA18  C3 FC0B                 	JP	HOME		;move head to home position
  FA1B  C3 FC10                 	JP	SELDSK		;select disk
  FA1E  C3 FC25                 	JP	SETTRK		;set track number
  FA21  C3 FC29                 	JP	SETSEC		;set sector number
  FA24  C3 FC3E                 	JP	SETDMA		;set dma address
  FA27  C3 FC45                 	JP	READ		;read disk
  FA2A  C3 FC49                 	JP	WRITE		;write disk
  FA2D  C3 FC01                 	JP	LISTST		;return list status
  FA30  C3 FC2D                 	JP	SECTRAN		;sector translate
                                ;
                                ;	fixed data tables for four-drive standard
                                ;	IBM-compatible 8" SD disks
                                ;
                                ;	 Drive 0 = A: (ROM disk 1)
Z80AS 4.8	Source file: BIOS01   	Page    2

  FA33  FAC3  0000              DPBASE:	DEFW	TRANS,0000H
  FA37  0000  0000              	DEFW	0000H,0000H
  FA3B  FC56  FADD              	DEFW	DIRBF,DPBLK
  FA3F  FD71  FCD6              	DEFW	CHK00,ALL00
                                ;	 Drive 1 = B: (ROM disk 2)
  FA43  FAC3  0000              	DEFW	TRANS,0000H
  FA47  0000  0000              	DEFW	0000H,0000H
  FA4B  FC56  FADD              	DEFW	DIRBF,DPBLK
  FA4F  FD81  FCF5              	DEFW	CHK01,ALL01
                                ;	 Drive 2 = C: (ROM disk 3)
  FA53  FAC3  0000              	DEFW	TRANS,0000H
  FA57  0000  0000              	DEFW	0000H,0000H
  FA5B  FC56  FADD              	DEFW	DIRBF,DPBLK
  FA5F  FD91  FD14              	DEFW	CHK02,ALL02
                                ;	 Drive 3 = D: (ROM disk 4)
  FA63  FAC3  0000              	DEFW	TRANS,0000H
  FA67  0000  0000              	DEFW	0000H,0000H
  FA6B  FC56  FADD              	DEFW	DIRBF,DPBLK
  FA6F  FDA1  FD33              	DEFW	CHK03,ALL03
                                ; --- Drive E, F, G, H (Dummy DPH) ---
  FA73  0000  0000  0000        	DEFW	0,0,0,0,0,0,0,0
  FA79  0000  0000  0000        
  FA7F  0000  0000              
  FA83  0000  0000  0000        	DEFW	0,0,0,0,0,0,0,0
  FA89  0000  0000  0000        
  FA8F  0000  0000              
  FA93  0000  0000  0000        	DEFW	0,0,0,0,0,0,0,0
  FA99  0000  0000  0000        
  FA9F  0000  0000              
  FAA3  0000  0000  0000        	DEFW	0,0,0,0,0,0,0,0
  FAA9  0000  0000  0000        
  FAAF  0000  0000              
                                ; --- Drive I: 128KB RAM Disk (9th Drive) ---
  FAB3  0000  0000              	DEFW	0000H,0000H	; XLT=0	
  FAB7  0000  0000              	DEFW	0000H,0000H
  FABB  FC56  FAEC              	DEFW	DIRBF, DPBI
  FABF  FDB1  FD52              	DEFW	CHK04, ALL04
                                
                                ;;	Drive 5 = F: (128KB RAM disk)
                                ;	DEFW	0000H,0000H
                                ;	DEFW	0000H,0000H
                                ;	DEFW	DIRBF,DPBB
                                ;	DEFW	CHK01,ALL01
                                ;	disk parameter header for disk 02
                                ;	DEFW	TRANS,0000H
                                ;	DEFW	0000H,0000H
                                ;	DEFW	DIRBF,DPBLK
                                ;	DEFW	CHK02,ALL02
                                ;	disk parameter header for disk 03
                                ;	DEFW	TRANS,0000H
                                ;	DEFW	0000H,0000H
                                ;	DEFW	DIRBF,DPBLK
                                ;	DEFW	CHK03,ALL03
                                
                                ;
                                ;	sector translate vector for the IBM 8" SD disks
                                ;
  FAC3  01 07 0D 13             TRANS:	DEFB	1,7,13,19	;sectors 1,2,3,4
Z80AS 4.8	Source file: BIOS01   	Page    3

  FAC7  19 05 0B 11             	DEFB	25,5,11,17	;sectors 5,6,7,8
  FACB  17 03 09 0F             	DEFB	23,3,9,15	;sectors 9,10,11,12
  FACF  15 02 08 0E             	DEFB	21,2,8,14	;sectors 13,14,15,16
  FAD3  14 1A 06 0C             	DEFB	20,26,6,12	;sectors 17,18,19,20
  FAD7  12 18 04 0A             	DEFB	18,24,4,10	;sectors 21,22,23,24
  FADB  10 16                   	DEFB	16,22		;sectors 25,26
                                ;
                                ;	disk parameter block, common to all IBM 8" SD disks
                                ;
  FADD  001A                    DPBLK:  DEFW	26		;sectors per track
  FADF  03                      	DEFB	3		;block shift factor
  FAE0  07                      	DEFB	7		;block mask
  FAE1  00                      	DEFB	0		;extent mask
  FAE2  00F2                    	DEFW	242		;disk size-1
  FAE4  003F                    	DEFW	63		;directory max
  FAE6  C0                      	DEFB	192		;alloc 0
  FAE7  00                      	DEFB	0		;alloc 1
  FAE8  0010                    	DEFW	16		;check size
  FAEA  0002                    	DEFW	2		;track offset
                                
                                ;; =============================================================
                                ;; Disk Parameter Block for RAM Disk (Drive 1 = B:, 36KB, 1KB/block)
                                ;; =============================================================
                                ;DPBB: DEFW      26              ; SPT  : sectors per track = 26
                                ;        DEFB    3               ; BSH  : block shift = 3 1KB/block
                                ;        DEFB    7               ; BLM  : block mask = 7
                                ;        DEFB    0               ; EXM  : extent mask
                                ;        DEFW    35              ; DSM  : disk size -1 (36 blocks x 1KB = 36KB)
                                ;        DEFW    31             ; DRM  : directory entries -1 (32 entries)
                                ;        DEFB    080H            ; AL0
                                ;        DEFB    00H             ; AL1
                                ;        DEFW    0000H           ; CKS  = 0 (RAM disk)
                                ;        DEFW    0000H           ; OFF  = 0
                                
                                ; =============================================================
                                ; Disk Parameter Block for RAM Disk (Drive 8 = I:, 128KB, 1KB/block)
                                ; =============================================================
  FAEC  001A                    DPBI: DEFW      26              ; SPT  : sectors per track = 26
  FAEE  03                              DEFB    3               ; BSH  : block shift = 3 1KB/block
  FAEF  07                              DEFB    7               ; BLM  : block mask = 7
  FAF0  00                              DEFB    0               ; EXM  : extent mask
  FAF1  007F                            DEFW    127             ; DSM  : disk size -1 (128 blocks x 1KB = 128KB)
  FAF3  003F                            DEFW    63              ; DRM  : directory entries -1 (64 entries)
  FAF5  C0                              DEFB    0C0H            ; AL0  : 1100 0000 (First 2 blocks for DIR)
  FAF6  00                              DEFB    00H             ; AL1 
  FAF7  0000                            DEFW    0000H           ; CKS  = 0 (RAM disk)
  FAF9  0000                            DEFW    0000H           ; OFF  = 0
                                
