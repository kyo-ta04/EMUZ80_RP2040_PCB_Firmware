                                ;;	fixed data tables for 4MB harddisks
                                ;;
                                ;;	disk parameter header
                                ;HDB1:	DEFW	0000H,0000H
                                ;	DEFW	0000H,0000H
                                ;	DEFW	DIRBF,HDBLK
                                ;	DEFW	CHKHD1,ALLHD1
                                ;HDB2:	DEFW	0000H,0000H
                                ;	DEFW	0000H,0000H
Z80AS 4.8	Source file: BIOS01   	Page    4

                                ;	DEFW	DIRBF,HDBLK
                                ;	DEFW	CHKHD2,ALLHD2
                                ;;
                                ;;       disk parameter block for harddisk
                                ;;
                                ;HDBLK:  DEFW    128		;sectors per track
                                ;	DEFB    4		;block shift factor
                                ;	DEFB    15		;block mask
                                ;	DEFB    0		;extent mask
                                ;	DEFW    2039		;disk size-1
                                ;	DEFW    1023		;directory max
                                ;	DEFB    255		;alloc 0
                                ;	DEFB    255		;alloc 1
                                ;	DEFW    0		;check size
                                ;	DEFW    0		;track offset
                                
                                ;
                                ;	messages
                                ;
  FAFB  36 34 4B 20 43 50       SIGNON: DEFM	'64K CP/M Vers. 2.2 (Z80 CBIOS V1.2 for Z80SIM, '
  FB01  2F 4D 20 56 65 72       
  FB07  73 2E 20 32 2E 32       
  FB0D  20 28 5A 38 30 20       
  FB13  43 42 49 4F 53 20       
  FB19  56 31 2E 32 20 66       
  FB1F  6F 72 20 5A 38 30       
  FB25  53 49 4D 2C 20          
  FB2A  43 6F 70 79 72 69       	DEFM	'Copyright 1988-2007 by Udo Munk)'
  FB30  67 68 74 20 31 39       
  FB36  38 38 2D 32 30 30       
  FB3C  37 20 62 79 20 55       
  FB42  64 6F 20 4D 75 6E       
  FB48  6B 29                   
  FB4A  0D 0A 00                	DEFB	13,10,0
                                ;
  FB4D  42 49 4F 53 3A 20       LDERR:	DEFM	'BIOS: error booting'
  FB53  65 72 72 6F 72 20       
  FB59  62 6F 6F 74 69 6E       
  FB5F  67                      
  FB60  0D 0A 00                	DEFB	13,10,0
                                
                                ;
                                ;	end of fixed tables
                                ;
                                ;	utility functions
                                ;
                                ;	print a 0 terminated string to console device
                                ;	pointer to string in HL
                                ;
  FB63  7E                      PRTMSG:	LD	A,(HL)
  FB64  B7                      	OR	A
  FB65  C8                      	RET	Z
  FB66  4F                      	LD	C,A
  FB67  CD FBF9                 	CALL	CONOUT
  FB6A  23                      	INC	HL
  FB6B  C3 FB63                 	JP	PRTMSG
                                ;
                                ;	individual subroutines to perform each function
Z80AS 4.8	Source file: BIOS01   	Page    5

                                ;	simplest case is to just perform parameter initialization
                                ;
  FB6E  31 0080                 BOOT:   LD	SP,80H		;use space below buffer for stack
  FB71  21 FAFB                 	LD	HL,SIGNON	;print message
  FB74  CD FB63                 	CALL	PRTMSG
  FB77  AF                      	XOR	A		;zero in the accum
  FB78  32 0003                 	LD	(IOBYTE),A	;clear the iobyte
  FB7B  32 0004                 	LD	(CDISK),A	;select disk zero
  FB7E  C3 FBCB                 	JP	GOCPM		;initialize and go to cp/m
                                ;
                                ;	simplest case is to read the disk until all sectors loaded
                                ;
  FB81  31 0080                 WBOOT:  LD	SP,80H		;use space below buffer for stack
  FB84  0E 00                   	LD	C,0		;select disk 0
  FB86  CD FC10                 	CALL	SELDSK
  FB89  CD FC0B                 	CALL	HOME		;go to track 00
                                ;
  FB8C  06 2C                   	LD	B,NSECTS	;b counts # of sectors to load
  FB8E  0E 00                   	LD	C,0		;c has the current track number
  FB90  16 02                   	LD	D,2		;d has the next sector to read
                                ;	note that we begin by reading track 0, sector 2 since sector 1
                                ;	contains the cold start loader, which is skipped in a warm start
  FB92  21 E400                 	LD	HL,CCP		;base of cp/m (initial load point)
  FB95                          LOAD1:				;load one more sector
  FB95  C5                      	PUSH	BC		;save sector count, current track
  FB96  D5                      	PUSH	DE		;save next sector to read
  FB97  E5                      	PUSH	HL		;save dma address
  FB98  4A                      	LD	C,D		;get sector address to register c
  FB99  CD FC29                 	CALL	SETSEC		;set sector address from register c
  FB9C  C1                      	POP	BC		;recall dma address to b,c
  FB9D  C5                      	PUSH	BC		;replace on stack for later recall
  FB9E  CD FC3E                 	CALL	SETDMA		;set dma address from b,c
                                ;	drive set to 0, track set, sector set, dma address set
  FBA1  CD FC45                 	CALL	READ
  FBA4  B7                      	OR	A		;any errors?
  FBA5  CA FBB0                 	JP	Z,LOAD2		;no, continue
  FBA8  21 FB4D                 	LD	HL,LDERR	;error, print message
  FBAB  CD FB63                 	CALL	PRTMSG
  FBAE  F3                      	DI			;and halt the machine
  FBAF  76                      	HALT
                                ;	no error, move to next sector
  FBB0  E1                      LOAD2:	POP	HL		;recall dma address
  FBB1  11 0080                 	LD	DE,128		;dma=dma+128
  FBB4  19                      	ADD	HL,DE		;new dma address is in h,l
  FBB5  D1                      	POP	DE		;recall sector address
  FBB6  C1                      	POP	BC		;recall number of sectors remaining,
                                				;and current trk
  FBB7  05                      	DEC	B		;sectors=sectors-1
  FBB8  CA FBCB                 	JP	Z,GOCPM		;transfer to cp/m if all have been loaded
                                ;	more sectors remain to load, check for track change
  FBBB  14                      	INC	D
  FBBC  7A                      	LD	A,D		;sector=27?, if so, change tracks
  FBBD  FE 1B                   	CP	27
  FBBF  DA FB95                 	JP	C,LOAD1		;carry generated if sector<27
                                ;	end of current track, go to next track
  FBC2  16 01                   	LD	D,1		;begin with first sector of next track
  FBC4  0C                      	INC	C		;track=track+1
                                ;	save register state, and change tracks
Z80AS 4.8	Source file: BIOS01   	Page    6

  FBC5  CD FC25                 	CALL	SETTRK		;track address set from register c
  FBC8  C3 FB95                 	JP	LOAD1		;for another sector
                                ;	end of load operation, set parameters and go to cp/m
  FBCB                          GOCPM:
  FBCB  3E C3                   	LD	A,0C3H		;c3 is a jmp instruction
  FBCD  32 0000                 	LD	(0),A		;for jmp to wboot
  FBD0  21 FA03                 	LD	HL,WBOOTE	;wboot entry point
  FBD3  22 0001                 	LD	(1),HL		;set address field for jmp at 0
                                ;
  FBD6  32 0005                 	LD	(5),A		;for jmp to bdos
  FBD9  21 EC06                 	LD	HL,BDOS		;bdos entry point
  FBDC  22 0006                 	LD	(6),HL		;address field of jump at 5 to bdos
                                ;
  FBDF  01 0080                 	LD	BC,80H		;default dma address is 80h
  FBE2  CD FC3E                 	CALL	SETDMA
                                ;
  FBE5  3A 0004                 	LD	A,(CDISK)	;get current disk number
  FBE8  4F                      	LD	C,A		;send to the ccp
  FBE9  C3 E400                 	JP	CCP		;go to cp/m for further processing
                                ;
                                ;
                                ;	simple i/o handlers
                                ;
                                ;	console status, return 0ffh if character ready, 00h if not
                                ;
  FBEC  DB 00                   CONST:	IN	A,(CONSTA)	;get console status
  FBEE  C9                      	RET
                                ;
                                ;	console character into register a
                                ;
  FBEF  CD FBEC                 CONIN:	CALL	CONST		;*** BIOS01 ADD ***
  FBF2  B7                      	OR	A
  FBF3  CA FBEF                 	JP	Z,CONIN
  FBF6  DB 01                   	IN	A,(CONDAT)	;get character from console
  FBF8  C9                      	RET
                                ;
                                ;	console character output from register c
                                ;
  FBF9  79                      CONOUT: LD	A,C		;get to accumulator
  FBFA  D3 01                   	OUT	(CONDAT),A	;send character to console
  FBFC  C9                      	RET
                                ;
                                ;	list character from register c
                                ;
  FBFD  79                      LIST:	LD	A,C		;character to register a
  FBFE  D3 03                   	OUT	(PRTDAT),A
  FC00  C9                      	RET
                                ;
                                ;	return list status (00h if not ready, 0ffh if ready)
                                ;
  FC01  DB 02                   LISTST: IN	A,(PRTSTA)
  FC03  C9                      	RET
                                ;
                                ;	punch character from register c
                                ;
  FC04  79                      PUNCH:	LD	A,C		;character to register a
  FC05  D3 05                   	OUT	(AUXDAT),A
  FC07  C9                      	RET
Z80AS 4.8	Source file: BIOS01   	Page    7

                                ;
                                ;	read character into register a from reader device
                                ;
  FC08  DB 05                   READER: IN	A,(AUXDAT)
  FC0A  C9                      	RET
                                ;
                                ;
                                ;	i/o drivers for the disk follow
                                ;
                                ;	move to the track 00 position of current drive
                                ;	translate this call into a settrk call with parameter 00
                                ;
  FC0B  0E 00                   HOME:	LD	C,0		;select track 0
  FC0D  C3 FC25                 	JP	SETTRK		;we will move to 00 on first read/write
                                ;;
                                ;;	select disk given by register C
                                ;;
                                ; SELDSK: LD	HL,0000H	;error return code
                                ; 	LD	A,C
                                ;	CP	4		;FD drive 0-3?
                                ;	JP	C,SELFD		;go
                                ;	CP	8		;harddisk 1?
                                ;	JP	Z,SELHD1	;go
                                ;	CP	9		;harddisk 2?
                                ;	JP	Z,SELHD2	;go
                                ;	RET			;no, error
                                ;;	disk number is in the proper range
                                ;;	compute proper disk parameter header address
                                ;SELFD:	OUT	(FDCD),A	;select disk drive
                                ;	LD	L,A		;L=disk number 0,1,2,3
                                ;	ADD	HL,HL		;*2
                                ;	ADD	HL,HL		;*4
                                ;	ADD	HL,HL		;*8
                                ;	ADD	HL,HL		;*16 (size of each header)
                                ;	LD	DE,DPBASE
                                ;	ADD	HL,DE		;HL=.dpbase(diskno*16)
                                ;	RET
                                ;SELHD1:	LD	HL,HDB1		;dph harddisk 1
                                ;	JP	SELHD
                                ;SELHD2:	LD	HL,HDB2		;dph harddisk 2
                                ;SELHD:	OUT	(FDCD),A	;select harddisk drive
                                ;	RET
                                
                                ; =============================================================
                                ; SELDSK - Select Disk (Modified for 2-Drive System)
                                ; =============================================================
  FC10  21 0000                 SELDSK: LD	HL,0000H	; Error return code
  FC13  79                      	LD	A,C
  FC14  FE 09                   	CP	9				; FD drive A-I? (0-8)
  FC16  D0                      	RET	NC				; Error	
  FC17  D3 0A                   	OUT	(FDCD),A		; Select disk drive for RP2040
                                	; DPH Address Calculation: HL = DPBASE + (A * 16)
  FC19  6F                      	LD      L, A
  FC1A  26 00                   	LD      H, 0
  FC1C  29                      	ADD     HL, HL          ; *2
  FC1D  29                      	ADD     HL, HL          ; *4
  FC1E  29                      	ADD     HL, HL          ; *8
  FC1F  29                      	ADD     HL, HL          ; *16
Z80AS 4.8	Source file: BIOS01   	Page    8

  FC20  11 FA33                 	LD      DE, DPBASE
  FC23  19                      	ADD     HL, DE
  FC24  C9                      	RET
                                
                                ;    CP      0
                                ;    JR      Z,SEL_A
                                ;    CP      1
                                ;    JR      Z,SEL_B
                                ;    ; 2 and 3 are error
                                ;    LD      HL,0000H
                                ;    RET
                                ;SEL_A:  LD      HL,DPBASE       ; Drive 0 DPH address
                                ;    RET
                                ;SEL_B:  LD      HL,DPBASE+16    ; Drive 1 DPH address
                                ;    RET
                                
                                ;
                                ;	set track given by register c
                                ;
  FC25  79                      SETTRK: LD	A,C
  FC26  D3 0B                   	OUT	(FDCT),A
  FC28  C9                      	RET
                                ;
                                ;	set sector given by register c
                                ;
  FC29  79                      SETSEC: LD	A,C
  FC2A  D3 0C                   	OUT	(FDCS),A
  FC2C  C9                      	RET
                                ;
                                ;	translate the sector given by BC using the
                                ;	translate table given by DE
                                ;
  FC2D                          SECTRAN:
  FC2D  7A                      	LD	A,D		;do we have a translation table?
  FC2E  B3                      	OR	E
  FC2F  C2 FC38                 	JP	NZ,SECT1	;yes, translate
  FC32  69                      	LD	L,C		;no, return untranslated
  FC33  60                      	LD	H,B		;in HL
  FC34  2C                      	INC	L		;sector no. start with 1
  FC35  C0                      	RET	NZ
  FC36  24                      	INC	H
  FC37  C9                      	RET
  FC38  EB                      SECT1:	EX	DE,HL		;HL=.trans
  FC39  09                      	ADD	HL,BC		;HL=.trans(sector)
  FC3A  6E                      	LD	L,(HL)		;L = trans(sector)
  FC3B  26 00                   	LD	H,0		;HL= trans(sector)
  FC3D  C9                      	RET			;with value in HL
                                ;
                                ;	set dma address given by registers b and c
                                ;
  FC3E  79                      SETDMA: LD	A,C		;low order address
  FC3F  D3 0F                   	OUT	(DMAL),A
  FC41  78                      	LD	A,B		;high order address
  FC42  D3 10                   	OUT	(DMAH),A	;in dma
  FC44  C9                      	RET
                                ;
                                ;	perform read operation
                                ;
Z80AS 4.8	Source file: BIOS01   	Page    9

  FC45  AF                      READ:	XOR	A		;read command -> A
  FC46  C3 FC4B                 	JP	WAITIO		;to perform the actual i/o
                                ;
                                ;	perform a write operation
                                ;
  FC49  3E 01                   WRITE:	LD	A,1		;write command -> A
                                ;
                                ;	enter here from read and write to perform the actual i/o
                                ;	operation.  return a 00h in register a if the operation completes
                                ;	properly, and 01h if an error occurs during the read or write
                                ;
  FC4B  D3 0D                   WAITIO: OUT	(FDCOP),A	;start i/o operation
  FC4D  DB 09                   WAITLP: IN	A,(09h)		;DMA status **** Add BIOS01 ****
  FC4F  B7                      	OR	A		;not 0 Busy
  FC50  C2 FC4D                 	JP	NZ,WAITLP 
  FC53  DB 0E                   	IN	A,(FDCST)	;status of i/o operation -> A
  FC55  C9                      	RET
                                ;
                                ;	the remainder of the CBIOS is reserved uninitialized
                                ;	data area, and does not need to be a part of the
                                ;	system memory image (the space must be available,
                                ;	however, between "begdat" and "enddat").
                                ;
                                ;	scratch ram area for BDOS use
                                ;
  FC56  =                       BEGDAT	EQU	$		;beginning of data area
  FC56  ( 0080 )                DIRBF:	DEFS	128		;scratch directory area
  FCD6  ( 001F )                ALL00:	DEFS	31		;allocation vector 0 A:
  FCF5  ( 001F )                ALL01:	DEFS	31		;allocation vector 1 B:
  FD14  ( 001F )                ALL02:	DEFS	31		;allocation vector 2 C:
  FD33  ( 001F )                ALL03:	DEFS	31		;allocation vector 3 D:
  FD52  ( 001F )                ALL04:	DEFS	31		;allocation vector 4 I:
                                ; ALLHD1:	DEFS	255		;allocation vector harddisk 1
                                ; ALLHD2:	DEFS	255		;allocation vector harddisk 2
  FD71  ( 0010 )                CHK00:	DEFS	16		;check vector 0 A:
  FD81  ( 0010 )                CHK01:	DEFS	16		;check vector 1 B:
  FD91  ( 0010 )                CHK02:	DEFS	16		;check vector 2 C:
  FDA1  ( 0010 )                CHK03:	DEFS	16		;check vector 3 D:
  FDB1  ( 0010 )                CHK04:	DEFS	16		;check vector 4 I:
                                ; CHKHD1:	DEFS	0		;check vector harddisk 1
                                ; CHKHD2:	DEFS	0		;check vector harddisk 2
                                ;
  FDC1  =                       ENDDAT	EQU	$		;end of data area
  016B  =                       DATSIZ	EQU	$-BEGDAT	;size of data area
                                ;
  0000  =                       	END			;of BIOS

Errors: 0
