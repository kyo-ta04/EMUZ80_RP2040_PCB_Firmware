                                ;	Z80 CBIOS for Z80-Simulator
                                ;
                                ;	Copyright (C) 1988-2007 by Udo Munk
                                ;
  0040  =                       MSIZE	EQU	64		;cp/m version memory size in kilobytes
                                ;
                                ;	"bias" is address offset from 3400H for memory systems
                                ;	than 16K (referred to as "b" throughout the text).
                                ;
  B000  =                       BIAS	EQU	(MSIZE-20)*1024
  E400  =                       CCP	EQU	3400H+BIAS	;base of ccp
  EC06  =                       BDOS	EQU	CCP+806H	;base of bdos
  FA00  =                       BIOS	EQU	CCP+1600H	;base of bios
  002C  =                       NSECTS	EQU	(BIOS-CCP)/128	;warm start sector count
  0004  =                       CDISK	EQU	0004H		;current disk number 0=A,...,15=P
  0003  =                       IOBYTE	EQU	0003H		;intel i/o byte
                                ;
                                ;	I/O ports
                                ;
  0000  =                       CONSTA	EQU	0		;console status port
  0001  =                       CONDAT	EQU	1		;console data port
  0002  =                       PRTSTA	EQU	2		;printer status port
  0003  =                       PRTDAT	EQU	3		;printer data port
  0005  =                       AUXDAT	EQU	5		;auxiliary data port
  000A  =                       FDCD	EQU	10		;fdc-port: # of drive
  000B  =                       FDCT	EQU	11		;fdc-port: # of track
  000C  =                       FDCS	EQU	12		;fdc-port: # of sector
  000D  =                       FDCOP	EQU	13		;fdc-port: command
  000E  =                       FDCST	EQU	14		;fdc-port: status
  000F  =                       DMAL	EQU	15		;dma-port: dma address low
  0010  =                       DMAH	EQU	16		;dma-port: dma address high
                                ;
  FA00  =                       	ORG	BIOS		;origin of this program
                                ;
                                ;	jump vector for individual subroutines
                                ;
  FA00  C3 FB4D                 	JP	BOOT		;cold start
  FA03  C3 FB60                 WBOOTE: JP	WBOOT		;warm start
  FA06  C3 FBCB                 	JP	CONST		;console status
  FA09  C3 FBCE                 	JP	CONIN		;console character in
  FA0C  C3 FBD8                 	JP	CONOUT		;console character out
  FA0F  C3 FBDC                 	JP	LIST		;list character out
  FA12  C3 FBE3                 	JP	PUNCH		;punch character out
  FA15  C3 FBE7                 	JP	READER		;reader character in
  FA18  C3 FBEA                 	JP	HOME		;move head to home position
  FA1B  C3 FBEF                 	JP	SELDSK		;select disk
  FA1E  C3 FC1B                 	JP	SETTRK		;set track number
  FA21  C3 FC1F                 	JP	SETSEC		;set sector number
  FA24  C3 FC34                 	JP	SETDMA		;set dma address
  FA27  C3 FC3B                 	JP	READ		;read disk
  FA2A  C3 FC3F                 	JP	WRITE		;write disk
  FA2D  C3 FBE0                 	JP	LISTST		;return list status
  FA30  C3 FC23                 	JP	SECTRAN		;sector translate
                                ;
                                ;	fixed data tables for four-drive standard
                                ;	IBM-compatible 8" SD disks
                                ;
                                ;	 Drive 0 = A: (ROM disk 1)
Z80AS 4.8	Source file: BIOS01   	Page    2

  FA33  FA73  0000              DPBASE:	DEFW	TRANS,0000H
  FA37  0000  0000              	DEFW	0000H,0000H
  FA3B  FC4C  FA8D              	DEFW	DIRBF,DPBLK
  FA3F  FF46  FCCC              	DEFW	CHK00,ALL00
                                ;	 Drive 1 = B: (ROM disk 2)
  FA43  FA73  0000              	DEFW	TRANS,0000H
  FA47  0000  0000              	DEFW	0000H,0000H
  FA4B  FC4C  FA8D              	DEFW	DIRBF,DPBLK
  FA4F  FF56  FCEB              	DEFW	CHK01,ALL01
                                ;	 Drive 2 = C: (ROM disk 3)
  FA53  FA73  0000              	DEFW	TRANS,0000H
  FA57  0000  0000              	DEFW	0000H,0000H
  FA5B  FC4C  FA8D              	DEFW	DIRBF,DPBLK
  FA5F  FF66  FD0A              	DEFW	CHK02,ALL02
                                ;	 Drive 3 = D: (ROM disk 4)
  FA63  FA73  0000              	DEFW	TRANS,0000H
  FA67  0000  0000              	DEFW	0000H,0000H
  FA6B  FC4C  FA8D              	DEFW	DIRBF,DPBLK
  FA6F  FF76  FD29              	DEFW	CHK03,ALL03
                                ;; --- Drive E, F, G, H (Dummy DPH) ---
                                ;	DEFW	0,0,0,0,0,0,0,0
                                ;	DEFW	0,0,0,0,0,0,0,0
                                ;	DEFW	0,0,0,0,0,0,0,0
                                ;	DEFW	0,0,0,0,0,0,0,0
                                
                                ;
                                ;	sector translate vector for the IBM 8" SD disks
                                ;
  FA73  01 07 0D 13             TRANS:	DEFB	1,7,13,19	;sectors 1,2,3,4
  FA77  19 05 0B 11             	DEFB	25,5,11,17	;sectors 5,6,7,8
  FA7B  17 03 09 0F             	DEFB	23,3,9,15	;sectors 9,10,11,12
  FA7F  15 02 08 0E             	DEFB	21,2,8,14	;sectors 13,14,15,16
  FA83  14 1A 06 0C             	DEFB	20,26,6,12	;sectors 17,18,19,20
  FA87  12 18 04 0A             	DEFB	18,24,4,10	;sectors 21,22,23,24
  FA8B  10 16                   	DEFB	16,22		;sectors 25,26
                                ;
                                ;	disk parameter block, common to all IBM 8" SD disks
                                ;
  FA8D  001A                    DPBLK:  DEFW	26		;sectors per track
  FA8F  03                      	DEFB	3		;block shift factor
  FA90  07                      	DEFB	7		;block mask
  FA91  00                      	DEFB	0		;extent mask
  FA92  00F2                    	DEFW	242		;disk size-1
  FA94  003F                    	DEFW	63		;directory max
  FA96  C0                      	DEFB	192		;alloc 0
  FA97  00                      	DEFB	0		;alloc 1
  FA98  0010                    	DEFW	16		;check size
  FA9A  0002                    	DEFW	2		;track offset
                                ;
                                ;	fixed data tables for 4MB harddisks
                                ;     -> ROM Disk (Drive I: 650KB, 2KB/block)
                                ;     -> RAM Disk (Drive J: 128KB, 1KB/block)
                                ;	disk parameter header
                                ; --- Drive I: 650KB ROM Disk (9th Drive) ---
  FA9C  0000  0000              HDB1:	DEFW	0000H,0000H	; XLT=0	
  FAA0  0000  0000              	DEFW	0000H,0000H
  FAA4  FC4C  FABC              	DEFW	DIRBF, DPBI
  FAA8  FF86  FD48              	DEFW	CHKHD1, ALLHD1
Z80AS 4.8	Source file: BIOS01   	Page    3

                                ; --- Drive J: 128KB RAM Disk (10th Drive) ---
  FAAC  0000  0000              HDB2:	DEFW	0000H,0000H	; XLT=0	
  FAB0  0000  0000              	DEFW	0000H,0000H
  FAB4  FC4C  FACB              	DEFW	DIRBF, DPBJ
  FAB8  FF86  FE47              	DEFW	CHKHD2, ALLHD2
                                ; =============================================================
                                ; Disk Parameter Block for ROM Disk (Drive 9 = I:, 650KB, 2KB/block)
                                ; =============================================================
  FABC  001A                    DPBI: DEFW      26              ; SPT  : sectors per track = 26
  FABE  04                              DEFB    4               ; BSH  : block shift = 4 2KB/block
  FABF  0F                              DEFB    15              ; BLM  : block mask = 15
  FAC0  00                              DEFB    0               ; EXM  : extent mask
  FAC1  0144                            DEFW    324             ; DSM  : disk size -1 (325 blocks x 2KB = 650KB)
  FAC3  003F                            DEFW    63              ; DRM  : directory entries -1 (64 entries)
  FAC5  C0                              DEFB    0C0H            ; AL0  : 1100 0000 (First 2 blocks for DIR)
  FAC6  00                              DEFB    00H             ; AL1 
  FAC7  0000                            DEFW    0000H           ; CKS  = 0 (ROM disk)
  FAC9  0000                            DEFW    0000H           ; OFF  = 0
                                
                                ; =============================================================
                                ; Disk Parameter Block for RAM Disk (Drive 10 = J:, 128KB, 1KB/block)
                                ; =============================================================
  FACB  001A                    DPBJ: DEFW      26              ; SPT  : sectors per track = 26
  FACD  03                              DEFB    3               ; BSH  : block shift = 3 1KB/block
  FACE  07                              DEFB    7               ; BLM  : block mask = 7
  FACF  00                              DEFB    0               ; EXM  : extent mask
  FAD0  007F                            DEFW    127             ; DSM  : disk size -1 (128 blocks x 1KB = 128KB)
  FAD2  003F                            DEFW    63              ; DRM  : directory entries -1 (64 entries)
  FAD4  C0                              DEFB    0C0H            ; AL0  : 1100 0000 (First 2 blocks for DIR)
  FAD5  00                              DEFB    00H             ; AL1 
  FAD6  0000                            DEFW    0000H           ; CKS  = 0 (RAM disk)
  FAD8  0000                            DEFW    0000H           ; OFF  = 0
                                
                                ;;
                                ;;	fixed data tables for 4MB harddisks
                                ;;
                                ;;	disk parameter header
                                ;HDB1:	DEFW	0000H,0000H
                                ;	DEFW	0000H,0000H
                                ;	DEFW	DIRBF,HDBLK
                                ;	DEFW	CHKHD1,ALLHD1
                                ;HDB2:	DEFW	0000H,0000H
                                ;	DEFW	0000H,0000H
                                ;	DEFW	DIRBF,HDBLK
                                ;	DEFW	CHKHD2,ALLHD2
                                ;;
                                ;;       disk parameter block for harddisk
                                ;;
                                ;HDBLK:  DEFW    128		;sectors per track
                                ;	DEFB    4		;block shift factor
                                ;	DEFB    15		;block mask
                                ;	DEFB    0		;extent mask
                                ;	DEFW    2039		;disk size-1
                                ;	DEFW    1023		;directory max
                                ;	DEFB    255		;alloc 0
                                ;	DEFB    255		;alloc 1
                                ;	DEFW    0		;check size
                                ;	DEFW    0		;track offset
Z80AS 4.8	Source file: BIOS01   	Page    4

                                
                                ;
                                ;	messages
                                ;
  FADA  36 34 4B 20 43 50       SIGNON: DEFM	'64K CP/M Vers. 2.2 (Z80 CBIOS V1.2 for Z80SIM, '
  FAE0  2F 4D 20 56 65 72       
  FAE6  73 2E 20 32 2E 32       
  FAEC  20 28 5A 38 30 20       
  FAF2  43 42 49 4F 53 20       
  FAF8  56 31 2E 32 20 66       
  FAFE  6F 72 20 5A 38 30       
  FB04  53 49 4D 2C 20          
  FB09  43 6F 70 79 72 69       	DEFM	'Copyright 1988-2007 by Udo Munk)'
  FB0F  67 68 74 20 31 39       
  FB15  38 38 2D 32 30 30       
  FB1B  37 20 62 79 20 55       
  FB21  64 6F 20 4D 75 6E       
  FB27  6B 29                   
  FB29  0D 0A 00                	DEFB	13,10,0
                                ;
  FB2C  42 49 4F 53 3A 20       LDERR:	DEFM	'BIOS: error booting'
  FB32  65 72 72 6F 72 20       
  FB38  62 6F 6F 74 69 6E       
  FB3E  67                      
  FB3F  0D 0A 00                	DEFB	13,10,0
                                
                                ;
                                ;	end of fixed tables
                                ;
                                ;	utility functions
                                ;
                                ;	print a 0 terminated string to console device
                                ;	pointer to string in HL
                                ;
  FB42  7E                      PRTMSG:	LD	A,(HL)
  FB43  B7                      	OR	A
  FB44  C8                      	RET	Z
  FB45  4F                      	LD	C,A
  FB46  CD FBD8                 	CALL	CONOUT
  FB49  23                      	INC	HL
  FB4A  C3 FB42                 	JP	PRTMSG
                                ;
                                ;	individual subroutines to perform each function
                                ;	simplest case is to just perform parameter initialization
                                ;
  FB4D  31 0080                 BOOT:   LD	SP,80H		;use space below buffer for stack
  FB50  21 FADA                 	LD	HL,SIGNON	;print message
  FB53  CD FB42                 	CALL	PRTMSG
  FB56  AF                      	XOR	A		;zero in the accum
  FB57  32 0003                 	LD	(IOBYTE),A	;clear the iobyte
  FB5A  32 0004                 	LD	(CDISK),A	;select disk zero
  FB5D  C3 FBAA                 	JP	GOCPM		;initialize and go to cp/m
                                ;
                                ;	simplest case is to read the disk until all sectors loaded
                                ;
  FB60  31 0080                 WBOOT:  LD	SP,80H		;use space below buffer for stack
  FB63  0E 00                   	LD	C,0		;select disk 0
  FB65  CD FBEF                 	CALL	SELDSK
Z80AS 4.8	Source file: BIOS01   	Page    5

  FB68  CD FBEA                 	CALL	HOME		;go to track 00
                                ;
  FB6B  06 2C                   	LD	B,NSECTS	;b counts # of sectors to load
  FB6D  0E 00                   	LD	C,0		;c has the current track number
  FB6F  16 02                   	LD	D,2		;d has the next sector to read
                                ;	note that we begin by reading track 0, sector 2 since sector 1
                                ;	contains the cold start loader, which is skipped in a warm start
  FB71  21 E400                 	LD	HL,CCP		;base of cp/m (initial load point)
  FB74                          LOAD1:				;load one more sector
  FB74  C5                      	PUSH	BC		;save sector count, current track
  FB75  D5                      	PUSH	DE		;save next sector to read
  FB76  E5                      	PUSH	HL		;save dma address
  FB77  4A                      	LD	C,D		;get sector address to register c
  FB78  CD FC1F                 	CALL	SETSEC		;set sector address from register c
  FB7B  C1                      	POP	BC		;recall dma address to b,c
  FB7C  C5                      	PUSH	BC		;replace on stack for later recall
  FB7D  CD FC34                 	CALL	SETDMA		;set dma address from b,c
                                ;	drive set to 0, track set, sector set, dma address set
  FB80  CD FC3B                 	CALL	READ
  FB83  B7                      	OR	A		;any errors?
  FB84  CA FB8F                 	JP	Z,LOAD2		;no, continue
  FB87  21 FB2C                 	LD	HL,LDERR	;error, print message
  FB8A  CD FB42                 	CALL	PRTMSG
  FB8D  F3                      	DI			;and halt the machine
  FB8E  76                      	HALT
                                ;	no error, move to next sector
  FB8F  E1                      LOAD2:	POP	HL		;recall dma address
  FB90  11 0080                 	LD	DE,128		;dma=dma+128
  FB93  19                      	ADD	HL,DE		;new dma address is in h,l
  FB94  D1                      	POP	DE		;recall sector address
  FB95  C1                      	POP	BC		;recall number of sectors remaining,
                                				;and current trk
  FB96  05                      	DEC	B		;sectors=sectors-1
  FB97  CA FBAA                 	JP	Z,GOCPM		;transfer to cp/m if all have been loaded
                                ;	more sectors remain to load, check for track change
  FB9A  14                      	INC	D
  FB9B  7A                      	LD	A,D		;sector=27?, if so, change tracks
  FB9C  FE 1B                   	CP	27
  FB9E  DA FB74                 	JP	C,LOAD1		;carry generated if sector<27
                                ;	end of current track, go to next track
  FBA1  16 01                   	LD	D,1		;begin with first sector of next track
  FBA3  0C                      	INC	C		;track=track+1
                                ;	save register state, and change tracks
  FBA4  CD FC1B                 	CALL	SETTRK		;track address set from register c
  FBA7  C3 FB74                 	JP	LOAD1		;for another sector
                                ;	end of load operation, set parameters and go to cp/m
  FBAA                          GOCPM:
  FBAA  3E C3                   	LD	A,0C3H		;c3 is a jmp instruction
  FBAC  32 0000                 	LD	(0),A		;for jmp to wboot
  FBAF  21 FA03                 	LD	HL,WBOOTE	;wboot entry point
  FBB2  22 0001                 	LD	(1),HL		;set address field for jmp at 0
                                ;
  FBB5  32 0005                 	LD	(5),A		;for jmp to bdos
  FBB8  21 EC06                 	LD	HL,BDOS		;bdos entry point
  FBBB  22 0006                 	LD	(6),HL		;address field of jump at 5 to bdos
                                ;
  FBBE  01 0080                 	LD	BC,80H		;default dma address is 80h
  FBC1  CD FC34                 	CALL	SETDMA
Z80AS 4.8	Source file: BIOS01   	Page    6

                                ;
  FBC4  3A 0004                 	LD	A,(CDISK)	;get current disk number
  FBC7  4F                      	LD	C,A		;send to the ccp
  FBC8  C3 E400                 	JP	CCP		;go to cp/m for further processing
                                ;
                                ;
                                ;	simple i/o handlers
                                ;
                                ;	console status, return 0ffh if character ready, 00h if not
                                ;
  FBCB  DB 00                   CONST:	IN	A,(CONSTA)	;get console status
  FBCD  C9                      	RET
                                ;
                                ;	console character into register a
                                ;
  FBCE  CD FBCB                 CONIN:	CALL	CONST		;*** BIOS01 ADD ***
  FBD1  B7                      	OR	A
  FBD2  CA FBCE                 	JP	Z,CONIN
  FBD5  DB 01                   	IN	A,(CONDAT)	;get character from console
  FBD7  C9                      	RET
                                ;
                                ;	console character output from register c
                                ;
  FBD8  79                      CONOUT: LD	A,C		;get to accumulator
  FBD9  D3 01                   	OUT	(CONDAT),A	;send character to console
  FBDB  C9                      	RET
                                ;
                                ;	list character from register c
                                ;
  FBDC  79                      LIST:	LD	A,C		;character to register a
  FBDD  D3 03                   	OUT	(PRTDAT),A
  FBDF  C9                      	RET
                                ;
                                ;	return list status (00h if not ready, 0ffh if ready)
                                ;
  FBE0  DB 02                   LISTST: IN	A,(PRTSTA)
  FBE2  C9                      	RET
                                ;
                                ;	punch character from register c
                                ;
  FBE3  79                      PUNCH:	LD	A,C		;character to register a
  FBE4  D3 05                   	OUT	(AUXDAT),A
  FBE6  C9                      	RET
                                ;
                                ;	read character into register a from reader device
                                ;
  FBE7  DB 05                   READER: IN	A,(AUXDAT)
  FBE9  C9                      	RET
                                ;
                                ;
                                ;	i/o drivers for the disk follow
                                ;
                                ;	move to the track 00 position of current drive
                                ;	translate this call into a settrk call with parameter 00
                                ;
  FBEA  0E 00                   HOME:	LD	C,0		;select track 0
  FBEC  C3 FC1B                 	JP	SETTRK		;we will move to 00 on first read/write
                                ;;
Z80AS 4.8	Source file: BIOS01   	Page    7

                                ;;	select disk given by register C
                                ;;
                                ; SELDSK: LD	HL,0000H	;error return code
                                ; 	LD	A,C
                                ;	CP	4		;FD drive 0-3?
                                ;	JP	C,SELFD		;go
                                ;	CP	8		;harddisk 1?
                                ;	JP	Z,SELHD1	;go
                                ;	CP	9		;harddisk 2?
                                ;	JP	Z,SELHD2	;go
                                ;	RET			;no, error
                                ;;	disk number is in the proper range
                                ;;	compute proper disk parameter header address
                                ;SELFD:	OUT	(FDCD),A	;select disk drive
                                ;	LD	L,A		;L=disk number 0,1,2,3
                                ;	ADD	HL,HL		;*2
                                ;	ADD	HL,HL		;*4
                                ;	ADD	HL,HL		;*8
                                ;	ADD	HL,HL		;*16 (size of each header)
                                ;	LD	DE,DPBASE
                                ;	ADD	HL,DE		;HL=.dpbase(diskno*16)
                                ;	RET
                                ;SELHD1:	LD	HL,HDB1		;dph harddisk 1
                                ;	JP	SELHD
                                ;SELHD2:	LD	HL,HDB2		;dph harddisk 2
                                ;SELHD:	OUT	(FDCD),A	;select harddisk drive
                                ;	RET
                                
                                ; =============================================================
                                ; SELDSK - Select Disk (Modified for 2-Drive System)
                                ; =============================================================
  FBEF  21 0000                 SELDSK: LD	HL,0000H	; Error return code
  FBF2  79                       	LD	A,C
  FBF3  FE 04                   	CP	4		;FD drive 0-3? (ROM1-4)
  FBF5  DA FC03                 	JP	C,SELFD		;go
  FBF8  FE 08                   	CP	8		;harddisk 1? (ROM5)
  FBFA  CA FC0F                 	JP	Z,SELHD1	;go
  FBFD  FE 09                   	CP	9		;harddisk 2? (RAM)
  FBFF  CA FC15                 	JP	Z,SELHD2	;go
  FC02  C9                      	RET			;no, error
                                ;	disk number is in the proper range
                                ;	compute proper disk parameter header address
  FC03  D3 0A                   SELFD:	OUT	(FDCD),A	;select disk drive
  FC05  6F                      	LD	L,A		;L=disk number 0,1,2,3
  FC06  29                      	ADD	HL,HL		;*2
  FC07  29                      	ADD	HL,HL		;*4
  FC08  29                      	ADD	HL,HL		;*8
  FC09  29                      	ADD	HL,HL		;*16 (size of each header)
  FC0A  11 FA33                 	LD	DE,DPBASE
  FC0D  19                      	ADD	HL,DE		;HL=.dpbase(diskno*16)
  FC0E  C9                      	RET
  FC0F  21 FA9C                 SELHD1:	LD	HL,HDB1		;dph harddisk 1
  FC12  C3 FC18                 	JP	SELHD
  FC15  21 FAAC                 SELHD2:	LD	HL,HDB2		;dph harddisk 2
  FC18  D3 0A                   SELHD:	OUT	(FDCD),A	;select harddisk drive
  FC1A  C9                      	RET
                                
                                ;---------------------
Z80AS 4.8	Source file: BIOS01   	Page    8

                                ;	LD	A,C
                                ;	CP	9				; FD drive A-J? (0-8)
                                ;	RET	NC				; Error	
                                ;	OUT	(FDCD),A		; Select disk drive for RP2040
                                ;	; DPH Address Calculation: HL = DPBASE + (A * 16)
                                ;	LD      L, A
                                ;	LD      H, 0
                                ;	ADD     HL, HL          ; *2
                                ;	ADD     HL, HL          ; *4
                                ;	ADD     HL, HL          ; *8
                                ;	ADD     HL, HL          ; *16
                                ;	LD      DE, DPBASE
                                ;	ADD     HL, DE
                                ;	RET
                                ;
                                
                                ;
                                ;	set track given by register c
                                ;
  FC1B  79                      SETTRK: LD	A,C
  FC1C  D3 0B                   	OUT	(FDCT),A
  FC1E  C9                      	RET
                                ;
                                ;	set sector given by register c
                                ;
  FC1F  79                      SETSEC: LD	A,C
  FC20  D3 0C                   	OUT	(FDCS),A
  FC22  C9                      	RET
                                ;
                                ;	translate the sector given by BC using the
                                ;	translate table given by DE
                                ;
  FC23                          SECTRAN:
  FC23  7A                      	LD	A,D		;do we have a translation table?
  FC24  B3                      	OR	E
  FC25  C2 FC2E                 	JP	NZ,SECT1	;yes, translate
  FC28  69                      	LD	L,C		;no, return untranslated
  FC29  60                      	LD	H,B		;in HL
  FC2A  2C                      	INC	L		;sector no. start with 1
  FC2B  C0                      	RET	NZ
  FC2C  24                      	INC	H
  FC2D  C9                      	RET
  FC2E  EB                      SECT1:	EX	DE,HL		;HL=.trans
  FC2F  09                      	ADD	HL,BC		;HL=.trans(sector)
  FC30  6E                      	LD	L,(HL)		;L = trans(sector)
  FC31  26 00                   	LD	H,0		;HL= trans(sector)
  FC33  C9                      	RET			;with value in HL
                                ;
                                ;	set dma address given by registers b and c
                                ;
  FC34  79                      SETDMA: LD	A,C		;low order address
  FC35  D3 0F                   	OUT	(DMAL),A
  FC37  78                      	LD	A,B		;high order address
  FC38  D3 10                   	OUT	(DMAH),A	;in dma
  FC3A  C9                      	RET
                                ;
                                ;	perform read operation
                                ;
Z80AS 4.8	Source file: BIOS01   	Page    9

  FC3B  AF                      READ:	XOR	A		;read command -> A
  FC3C  C3 FC41                 	JP	WAITIO		;to perform the actual i/o
                                ;
                                ;	perform a write operation
                                ;
  FC3F  3E 01                   WRITE:	LD	A,1		;write command -> A
                                ;
                                ;	enter here from read and write to perform the actual i/o
                                ;	operation.  return a 00h in register a if the operation completes
                                ;	properly, and 01h if an error occurs during the read or write
                                ;
  FC41  D3 0D                   WAITIO: OUT	(FDCOP),A	;start i/o operation
  FC43  DB 09                   WAITLP: IN	A,(09h)		;DMA status **** Add BIOS01 ****
  FC45  B7                      	OR	A		;not 0 Busy
  FC46  C2 FC43                 	JP	NZ,WAITLP 
  FC49  DB 0E                   	IN	A,(FDCST)	;status of i/o operation -> A
  FC4B  C9                      	RET
                                ;
                                ;	the remainder of the CBIOS is reserved uninitialized
                                ;	data area, and does not need to be a part of the
                                ;	system memory image (the space must be available,
                                ;	however, between "begdat" and "enddat").
                                ;
                                ;	scratch ram area for BDOS use
                                ;
  FC4C  =                       BEGDAT	EQU	$		;beginning of data area
  FC4C  ( 0080 )                DIRBF:	DEFS	128		;scratch directory area
  FCCC  ( 001F )                ALL00:	DEFS	31		;allocation vector 0 A:
  FCEB  ( 001F )                ALL01:	DEFS	31		;allocation vector 1 B:
  FD0A  ( 001F )                ALL02:	DEFS	31		;allocation vector 2 C:
  FD29  ( 001F )                ALL03:	DEFS	31		;allocation vector 3 D:
                                ; ALL04:	DEFS	31		;allocation vector 4 I:
  FD48  ( 00FF )                ALLHD1:	DEFS	255		;allocation vector harddisk 1
  FE47  ( 00FF )                ALLHD2:	DEFS	255		;allocation vector harddisk 2
  FF46  ( 0010 )                CHK00:	DEFS	16		;check vector 0 A:
  FF56  ( 0010 )                CHK01:	DEFS	16		;check vector 1 B:
  FF66  ( 0010 )                CHK02:	DEFS	16		;check vector 2 C:
  FF76  ( 0010 )                CHK03:	DEFS	16		;check vector 3 D:
                                ; CHK04:	DEFS	16		;check vector 4 I:
  FF86  ( 0000 )                CHKHD1:	DEFS	0		;check vector harddisk 1 (I:)
  FF86  ( 0000 )                CHKHD2:	DEFS	0		;check vector harddisk 2 (J:)
                                ;
  FF86  =                       ENDDAT	EQU	$		;end of data area
  033A  =                       DATSIZ	EQU	$-BEGDAT	;size of data area
                                ;
  0000  =                       	END			;of BIOS

